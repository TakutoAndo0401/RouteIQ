{
  "name": "@routeiq/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter @routeiq/contracts build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @routeiq/contracts build && tsx watch src/index.ts",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "pnpm --filter @routeiq/contracts build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@routeiq/contracts": "workspace:*",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
